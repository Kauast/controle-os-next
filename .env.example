# Banco de dados PostgreSQL
POSTGRES_USER=controle_os_user
POSTGRES_PASSWORD=           # gere com: openssl rand -base64 32
POSTGRES_DB=controle_os

# Redis
REDIS_PASSWORD=              # gere com: openssl rand -base64 32

# JWT — deve ser idêntico no backend e frontend
JWT_SECRET=                  # gere com: openssl rand -base64 64

# URLs
FRONTEND_URL=https://seu-dominio.com
ALLOWED_ORIGINS=https://seu-dominio.com

# Senhas dos usuários criados pelo seed (obrigatório em produção)
SEED_ADMIN_PASS=             # senha do admin@controle.com
SEED_STOCK_PASS=             # senha do estoque@controle.com
SEED_TECH_PASS=              # senha do tecnico@controle.com
SEED_ATTENDANT_PASS=         # senha do atendimento@controle.com
SEED_FINANCIAL_PASS=         # senha do financeiro@controle.com
