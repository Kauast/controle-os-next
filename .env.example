# Use como base para .env em produção.
# Gere senhas fortes com: openssl rand -base64 32 (DB/Redis) e openssl rand -base64 64 (JWT)
#
# VARIÁVEIS OBRIGATÓRIAS em NODE_ENV=production:
# - DOMAIN, POSTGRES_PASSWORD, JWT_SECRET, REDIS_PASSWORD, APP_URL, ANTHROPIC_API_KEY, METRICS_TOKEN
#
# Veja backend-senior/DEPLOY.md para checklist completo.

# ─── Domínio ────────────────────────────────────────────────────
DOMAIN=seu-dominio.com

# ─── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_USER=controle_os_user
POSTGRES_PASSWORD=           # openssl rand -base64 32 (OBRIGATÓRIO)
POSTGRES_DB=controle_os

# ─── Redis ───────────────────────────────────────────────────────
REDIS_PASSWORD=              # openssl rand -base64 32 (OBRIGATÓRIO)

# ─── JWT — mesmo valor no backend e frontend ─────────────────────
JWT_SECRET=                  # openssl rand -base64 64 (OBRIGATÓRIO)
JWT_EXPIRES_IN=8h

# ─── APP_URL ─────────────────────────────────────────────────────
# URL pública da aplicação — OBRIGATÓRIA em NODE_ENV=production
# Usada para gerar links de reset de senha (previne Host Header Injection)
# Deve incluir protocolo (https://) e ser válida
APP_URL=https://seu-dominio.com

# ─── CORS — origens permitidas ───────────────────────────────────
ALLOWED_ORIGINS=https://${DOMAIN}

# ─── Uploads ─────────────────────────────────────────────────────
UPLOAD_BASE_URL=https://${DOMAIN}/uploads

# ─── Armazenamento de Arquivos ──────────────────────────────────
# local = pasta /app/uploads (default)
# s3    = MinIO ou AWS S3
STORAGE_PROVIDER=local
# Se STORAGE_PROVIDER=s3, preencher abaixo:
# S3_ENDPOINT=http://minio:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=               # openssl rand -base64 32
# S3_BUCKET=controle-os-uploads
# S3_PUBLIC_URL=https://${DOMAIN}/uploads

# ─── Métricas — token para proteger o endpoint /metrics ──────────
METRICS_TOKEN=               # openssl rand -base64 32 (OBRIGATÓRIO)

# ─── Certbot / Let's Encrypt ─────────────────────────────────────
CERTBOT_EMAIL=seu@email.com

# ─── Grafana ─────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=       # openssl rand -base64 24

# ─── SMTP (e-mail de reset de senha) ─────────────────────────────
# Se deixar em branco, o sistema loga no console (dev apenas)
SMTP_HOST=smtp.exemplo.com.br
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@exemplo.com.br
SMTP_PASS=
SMTP_FROM=Guardiao <noreply@exemplo.com.br>

# ─── IA — Anthropic Claude (triagem automática de OS) ────────────
# Obrigatório em produção. Sem chave, endpoints /api/ai retornam 503.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ─── Seed (senha padrão para todos os usuários de seed) ──────────
SEED_DEFAULT_PASS=            # openssl rand -base64 16
SEED_ADMIN_PASS=              # senha do admin@controle.com
SEED_STOCK_PASS=              # senha do estoque@controle.com
SEED_TECH_PASS=               # senha do tecnico@controle.com
SEED_ATTENDANT_PASS=          # senha do atendimento@controle.com
SEED_FINANCIAL_PASS=          # senha do financeiro@controle.com

# ─── Uptime Kuma Push URLs para Alertmanager (opcional) ──────────
# UPTIME_KUMA_PUSH_URL=
# UPTIME_KUMA_CRITICAL_PUSH_URL=
