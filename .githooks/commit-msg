#!/bin/bash

# Git Hook: Validar formato Conventional Commits
# Executa antes de criar commit
# Se falhar, commit é abortado

COMMIT_MSG_FILE=$1
COMMIT_TYPE_REGEX="^(feat|fix|refactor|perf|docs|test|chore|ci|style|revert)"

# Ler mensagem do commit
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Ignorar merge commits
if [[ $COMMIT_MSG =~ ^Merge ]]; then
  exit 0
fi

# Ignorar revert automático do git
if [[ $COMMIT_MSG =~ ^Revert ]]; then
  exit 0
fi

# Validar formato Conventional Commits
if ! echo "$COMMIT_MSG" | head -1 | grep -qE "$COMMIT_TYPE_REGEX"; then
  echo ""
  echo "❌ ERRO: Mensagem de commit não segue Conventional Commits"
  echo ""
  echo "Formato esperado:"
  echo "  <tipo>(<escopo>): <descrição>"
  echo ""
  echo "Tipos válidos: feat, fix, refactor, perf, docs, test, chore, ci, style, revert"
  echo ""
  echo "Exemplos:"
  echo "  feat(auth): implementa OAuth2"
  echo "  fix(backend): corrige race condition"
  echo "  docs: atualiza README"
  echo ""
  exit 1
fi

# Validar que primeira linha tem no máximo 72 caracteres
FIRST_LINE=$(echo "$COMMIT_MSG" | head -1)
FIRST_LINE_LENGTH=${#FIRST_LINE}

if [ $FIRST_LINE_LENGTH -gt 72 ]; then
  echo ""
  echo "⚠️  AVISO: Primeira linha tem ${FIRST_LINE_LENGTH} caracteres (máximo: 72)"
  echo ""
fi

exit 0
