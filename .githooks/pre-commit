#!/bin/bash

# Git Hook: Validações antes de fazer commit
# Executa antes de confirmar mudanças
# Previne commits com código quebrado ou sem linting

# Cores
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

echo "🔍 Executando validações pré-commit..."

# 1. Verificar se não há arquivos .env sensíveis
echo "→ Validando variáveis de ambiente..."
for f in .env backend-senior/.env; do
  if git diff --cached --name-only | grep -q "^$f$"; then
    echo -e "${RED}❌ ERRO: Tentativa de commitar arquivo sensível '$f'${NC}"
    echo "Use: git rm --cached $f"
    exit 1
  fi
done

# 2. Verificar lint de arquivos modificados
echo "→ Verificando lint..."
CHANGED_FILES=$(git diff --cached --name-only | grep -E "\.(ts|tsx|js|jsx)$")

if [ -n "$CHANGED_FILES" ]; then
  # Lint apenas em TS/JS quando houver
  if npm run lint -- $CHANGED_FILES 2>&1; then
    echo -e "${GREEN}  ✓ Lint OK${NC}"
  else
    echo -e "${RED}❌ ERRO: Lint falhou. Execute 'npm run lint' para corrigir${NC}"
    exit 1
  fi
fi

# 3. Typecheck de arquivos TS/TSX
echo "→ Verificando tipos TypeScript..."
CHANGED_TS=$(git diff --cached --name-only | grep -E "\.(ts|tsx)$")

if [ -n "$CHANGED_TS" ]; then
  if npx tsc --noEmit 2>&1 | head -20; then
    echo -e "${GREEN}  ✓ TypeScript OK${NC}"
  else
    echo -e "${RED}❌ ERRO: TypeScript tem erros de tipo${NC}"
    exit 1
  fi
fi

# 4. Avisos
echo "→ Verificando boas práticas..."

# Avisar sobre console.log em produção
if git diff --cached | grep -E "console\.(log|error|warn|info)" | grep -v "^\+" | grep -q "."; then
  echo -e "${YELLOW}⚠️  Aviso: Encontrados console.log/error/warn${NC}"
  echo "   Se intencional, tudo bem. Caso contrário, remova-os."
fi

# Avisar sobre debugger; em código
if git diff --cached | grep "debugger;" | grep -q "."; then
  echo -e "${YELLOW}⚠️  Aviso: Encontrado 'debugger;' no código${NC}"
  echo "   Remova antes de commitar."
fi

echo ""
echo -e "${GREEN}✅ Validações pré-commit OK${NC}"
exit 0
