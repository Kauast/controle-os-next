# Desenvolvimento local (ajuste conforme docker-compose ou banco gerenciado)
DATABASE_URL=postgresql://controle_os_user:PASSWORD@localhost:5432/controle_os
REDIS_URL=redis://:PASSWORD@localhost:6379

# JWT — mesmo valor usado no frontend
JWT_SECRET=                  # gere com: openssl rand -base64 64

PORT=3333
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000
