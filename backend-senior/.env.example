# ─── Banco de dados ───────────────────────────────────────────────────────────
# Aponta para PgBouncer em produção; direto ao postgres em desenvolvimento
DATABASE_URL=postgresql://controle_os_user:PASSWORD@localhost:5432/controle_os
# URL direta (sem PgBouncer) — usada por `prisma migrate deploy`
DIRECT_URL=postgresql://controle_os_user:PASSWORD@localhost:5432/controle_os

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:PASSWORD@localhost:6379
# gere com: openssl rand -base64 32
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# gere com: openssl rand -base64 64
JWT_SECRET=
JWT_EXPIRES_IN=8h
JWT_ISSUER=controle-os-api
JWT_AUDIENCE=controle-os-client

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3333
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# URL pública da aplicação — OBRIGATÓRIA em produção (NODE_ENV=production)
# Usada para gerar links de reset de senha sem depender de headers HTTP (previne Host Header Injection)
APP_URL=https://seu-dominio.com

# ─── Rate limit e timeout ─────────────────────────────────────────────────────
REQUEST_TIMEOUT_MS=30000
RATE_LIMIT_MAX=300
LOGIN_RATE_LIMIT_MAX=20

# ─── Observabilidade ──────────────────────────────────────────────────────────
# gere com: openssl rand -base64 32
METRICS_TOKEN=

# ─── Armazenamento de arquivos (local | s3) ───────────────────────────────────
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=http://localhost:3333/uploads

# S3 / MinIO — necessário apenas quando STORAGE_PROVIDER=s3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=controle-os-uploads
S3_PUBLIC_URL=http://localhost:9000/controle-os-uploads

# ─── E-mail (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# ─── IA (Anthropic) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ─── Docker Compose — PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=controle_os_user
# gere com: openssl rand -base64 32
POSTGRES_PASSWORD=
POSTGRES_DB=controle_os

# ─── Docker Compose — MinIO ───────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
# gere com: openssl rand -base64 32
MINIO_ROOT_PASSWORD=

# ─── Docker Compose — Grafana ─────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
# gere com: openssl rand -base64 32
GRAFANA_ADMIN_PASSWORD=

# ─── Docker Compose — Domínio ─────────────────────────────────────────────────
DOMAIN=example.com

# ─── Seed (execução manual apenas) ───────────────────────────────────────────
SEED_DEFAULT_PASS=
SEED_ADMIN_PASS=
SEED_STOCK_PASS=
SEED_TECH_PASS=
SEED_ATTENDANT_PASS=
SEED_FINANCIAL_PASS=
