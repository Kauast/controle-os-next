# ─── Banco de Dados ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/controle_os_notifications"

# ─── Servidor ──────────────────────────────────────────────────────────────────
PORT=3334
NODE_ENV=development
LOG_LEVEL=debug
APP_VERSION=1.0.0

# ─── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL="amqp://guest:guest@localhost:5672"
RABBITMQ_EXCHANGE="controle-os-events"
RABBITMQ_QUEUE="notification-service"
RABBITMQ_RETRY_QUEUE="notification.retry"
# Prefetch: quantas mensagens o consumer processa em paralelo
RABBITMQ_PREFETCH=10

# ─── SMTP (deixe em branco para modo dev — apenas loga o e-mail) ───────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Controle OS <noreply@controle-os.app>"

# ─── Métricas ──────────────────────────────────────────────────────────────────
# Token para proteger o endpoint /metrics. Deixe vazio em dev.
METRICS_TOKEN=

# ─── Rate Limit ────────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=10000

# ─── Retry ─────────────────────────────────────────────────────────────────────
# Delay em ms para reagendar notificações com falha (padrão: 120000 = 2 min)
RETRY_DELAY_MS=120000
# Máximo de tentativas antes de marcar como FAILED permanentemente
MAX_RETRY_COUNT=3
