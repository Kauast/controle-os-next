# ── Banco de dados ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/service_order_db"

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3334
NODE_ENV=development
APP_VERSION=1.0.0

# ── JWT (validação apenas — não emite tokens) ─────────────────────────────────
JWT_SECRET=your-jwt-secret-here
JWT_ISSUER=controle-os-api
JWT_AUDIENCE=controle-os-client

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=os-events
RABBITMQ_QUEUE_DLQ=os-events.dlq

# ── Serviços externos (Circuit Breaker via opossum) ───────────────────────────
CUSTOMER_SVC_URL=http://localhost:3335
WORKFORCE_SVC_URL=http://localhost:3336
INVENTORY_SVC_URL=http://localhost:3337
CHIP_SVC_URL=http://localhost:3338

# ── Observabilidade ───────────────────────────────────────────────────────────
METRICS_TOKEN=
LOG_LEVEL=info

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=300

# ── Timeout de requisições (ms) ───────────────────────────────────────────────
REQUEST_TIMEOUT_MS=30000

# ── Circuit Breaker ───────────────────────────────────────────────────────────
CB_TIMEOUT_MS=3000
CB_ERROR_THRESHOLD=50
CB_RESET_TIMEOUT_MS=10000

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
