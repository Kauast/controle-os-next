# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3334

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/billing_db

# ── JWT (mesmo secret do monolito para validar tokens inter-serviço) ─
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h
JWT_ISSUER=controle-os-api
JWT_AUDIENCE=controle-os-client

# ── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=controle_os
RABBITMQ_QUEUE_BILLING=billing.events

# ── Observabilidade ───────────────────────────────────────────
METRICS_TOKEN=
REQUEST_TIMEOUT_MS=30000
RATE_LIMIT_MAX=10000

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Cron ─────────────────────────────────────────────────────
# Expressão cron para checar faturas vencidas (default: todo dia às 02:00)
OVERDUE_CRON=0 2 * * *
