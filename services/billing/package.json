{
  "name": "billing-service",
  "version": "1.0.0",
  "description": "Billing microservice for controle-os-next",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && (tsc || true)",
    "start": "node dist/server.js",
    "migrate:dev": "prisma migrate dev --schema=prisma/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "studio": "prisma studio --schema=prisma/schema.prisma",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^6.19.3",
    "amqplib": "^0.10.4",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "node-cron": "^3.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/node": "^25.9.2",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^4.1.8",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}