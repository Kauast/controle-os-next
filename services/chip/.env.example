# Application
NODE_ENV=development
PORT=3002
LOG_LEVEL=debug
APP_VERSION=1.0.0

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/chip_service

# JWT (apenas validação — emissão é responsabilidade do Identity Service)
JWT_SECRET=your-jwt-secret-here

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=controle-os
RABBITMQ_QUEUE_OS_COMPLETED=chip-service.os.completed
RABBITMQ_QUEUE_CLIENT_DELETED=chip-service.client.deleted

# CORS
CORS_ORIGIN=http://localhost:3000
