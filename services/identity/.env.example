# ─── Identity Service — Variáveis de Ambiente ─────────────────────────────────
# Copie para .env e preencha com os valores reais.
# Nunca commite o .env real.

# Aplicação
NODE_ENV=development
PORT=3334
APP_VERSION=1.0.0
LOG_LEVEL=info

# Banco de dados ISOLADO do Identity Service
# Pode ser o mesmo Postgres do monólito em dev, mas com schema separado em prod.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/identity_db
# DIRECT_URL é necessário se usar PgBouncer em modo transaction
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/identity_db

# JWT — ÚNICO emissor de tokens
# Deve ter ao menos 32 caracteres. Mesma secret usada por todos os outros serviços para VERIFICAR.
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio-min-32-chars
JWT_EXPIRES_IN=8h
JWT_ISSUER=identity-svc
JWT_AUDIENCE=controle-os

# URL base do app (obrigatória em produção — usada nos links de reset de senha)
# APP_URL=https://seu-dominio.com

# SMTP (opcional — em dev os e-mails são apenas logados)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=sua-api-key
# SMTP_FROM=noreply@seu-dominio.com

# RabbitMQ (opcional — sem ele os eventos não são publicados, mas o serviço funciona)
# RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=controle-os.events

# Métricas Prometheus (deixe em branco para desativar autenticação em dev)
# METRICS_TOKEN=token-secreto-do-prometheus

# Rate limit
RATE_LIMIT_MAX=300
LOGIN_RATE_LIMIT_MAX=20
REQUEST_TIMEOUT_MS=30000

# CORS (separar múltiplas origens por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
