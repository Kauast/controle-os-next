# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3002
HOST=0.0.0.0
APP_VERSION=1.0.0
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/workforce_db

# ─── Auth (JWT validado, não emitido aqui) ────────────────────────────────────
# Deve ser idêntico ao secret usado pelo Identity Service
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ─── Service dependencies (REST síncrono) ─────────────────────────────────────
SERVICE_ORDER_SVC_URL=http://localhost:3001
