# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (somente dominio Customer)
DATABASE_URL=postgresql://postgres:password@localhost:5432/customer_db

# ─── Auth ────────────────────────────────────────────────────────────────────
# Mesma secret usada pelo Identity Service para assinar os JWTs
# Minimo 32 caracteres
JWT_SECRET=change_me_to_a_strong_secret_of_at_least_32_chars

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=controle-os

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development
LOG_LEVEL=debug
APP_VERSION=1.0.0
