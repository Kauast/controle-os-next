# ─── Media Service — variáveis de ambiente ───────────────────────────────────
# Copie para .env e preencha com seus valores reais.

# ─── Servidor ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3340
SERVICE_HOST=0.0.0.0

# ─── Banco de dados ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/controle_os_media?schema=public

# ─── Message Broker (RabbitMQ) ────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ─── Storage ─────────────────────────────────────────────────────────────────
# Valores: "local" | "s3"
STORAGE_PROVIDER=local

# Local: caminho base onde os arquivos serão salvos
STORAGE_LOCAL_PATH=./uploads

# S3 / MinIO (necessário quando STORAGE_PROVIDER=s3)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=controle-os-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# ─── Limites de upload ───────────────────────────────────────────────────────
# Tamanho máximo em bytes (padrão: 10485760 = 10 MB)
MAX_FILE_SIZE=10485760

# MIME types permitidos separados por vírgula
ALLOWED_MIME_TYPES=image/jpeg,image/png,application/pdf

# ─── Autenticação (JWT compartilhado com o monólito) ─────────────────────────
JWT_SECRET=troque-por-uma-chave-secreta-forte
JWT_ISSUER=controle-os-api
JWT_AUDIENCE=controle-os-client

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Observabilidade ─────────────────────────────────────────────────────────
# Token para proteger o endpoint /metrics (opcional, mas recomendado em produção)
METRICS_TOKEN=

# Timeout global de requisições em ms (padrão: 30000)
REQUEST_TIMEOUT_MS=30000

# Máximo de requisições por minuto por company/IP
RATE_LIMIT_MAX=300
