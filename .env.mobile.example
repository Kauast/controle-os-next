# Variáveis de ambiente para o build mobile (Capacitor/APK)
# Copie para .env.local e ajuste os valores antes de rodar:
#   npm run build:mobile

# URL do backend Fastify acessível pelo dispositivo Android
# Em desenvolvimento: use o IP da sua máquina na rede local (não localhost!)
# Exemplo LAN:  http://192.168.1.100:3333
# Produção:     https://api.seudominio.com
NEXT_PUBLIC_FASTIFY_URL=http://192.168.1.100:3333
